# ─── Servidor ─────────────────────────────────────────────────
PORT=8000
# Origen permitido para CORS (la URL del frontend)
CORS_ORIGIN="http://localhost:5173"

# ─── Seguridad ────────────────────────────────────────────────
# DEBE ser EXACTAMENTE el mismo JWT_SECRET que el backend Node,
# para que este servicio valide los tokens que emite Node.
JWT_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria"

# ─── Base de datos ────────────────────────────────────────────
# La MISMA connection string que usa Prisma en el backend.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brote?schema=public"

# ─── IA: Google Gemini ────────────────────────────────────────
# Consíguela gratis en https://aistudio.google.com/apikey
# Si la dejas vacía, el servicio arranca en modo "fake" (respuestas simuladas)
# para poder probar el flujo sin gastar cuota.
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
EMBEDDING_MODEL="models/text-embedding-004"

# ─── RAG / ChromaDB ───────────────────────────────────────────
CHROMA_DIR="chroma_db"
CHROMA_COLLECTION="brote-recursos"
