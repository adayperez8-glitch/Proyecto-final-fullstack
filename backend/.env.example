# ─── Base de datos (PostgreSQL) ───────────────────────────────
# Local: postgresql://USER:PASS@localhost:5432/brote?schema=public
# Nube (Railway/Supabase): pega aquí la connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brote?schema=public"

# ─── Autenticación (JWT) ──────────────────────────────────────
JWT_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria"
JWT_EXPIRES_IN="7d"

# ─── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
# Origen permitido para CORS (la URL del frontend)
CORS_ORIGIN="http://localhost:5173"

# ─── Automatizaciones (N8N) ───────────────────────────────────
# Clave compartida con N8N para los endpoints internos (/api/maintenance/*).
# Genera una cadena larga y aleatoria. Si la dejas vacía, esos endpoints
# quedan deshabilitados (devuelven 401).
INTERNAL_API_KEY=""
# URL del webhook del workflow "coach de ánimo" en N8N. Si la dejas vacía,
# la API simplemente no avisa al coach (no rompe nada).
# Ej.: https://TU-N8N/webhook/brote-mood
MOOD_COACH_WEBHOOK_URL=""

# ─── Almacenamiento de archivos (Cloudinary) ─────────────────
# Para que las fotos/vídeos de historias persistan en producción (en hosting
# con disco efímero como Render). Crea una cuenta gratis en cloudinary.com y
# pega aquí su "API Environment variable". Si la dejas vacía, los archivos se
# guardan en disco local (cómodo en desarrollo, NO persiste en hosting).
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=""

# ─── Integración externa: Email (nodemailer) ──────────────────
# Si no defines SMTP_*, en desarrollo los emails se imprimen por consola.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Brote <hola@brote.app>"
